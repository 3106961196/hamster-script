#!/bin/bash

if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" || "$OSTYPE" == "win32" ]]; then
    echo "错误：此脚本需要在 Linux 环境中运行"
    exit 1
fi

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PROJECT_ROOT

source "$PROJECT_ROOT/lib/core.sh"
init_core

_show_help() {
    echo "用法: cs [命令]"
    echo ""
    echo "命令:"
    echo "  (无参数)    启动主菜单"
    echo "  update, r   更新脚本"
    echo "  tmux        进入 tmux 桌面"
    echo "  version     显示版本"
    echo "  help, -h    查看帮助"
}

main() {
    if [[ $# -gt 0 ]]; then
        case "$1" in
            r|update)
                load_module "update"
                update_do
                ;;
            tmux)
                export HAMSTER_ROOT="$PROJECT_ROOT"
                exec bash "$PROJECT_ROOT/config/tmux/tmux.sh" "${@:2}"
                ;;
            version)
                echo "${PROJECT_NAME} v${PROJECT_VERSION}"
                ;;
            help|-h|--help)
                _show_help
                ;;
            *)
                echo "未知命令: $1"
                echo ""
                _show_help
                exit 1
                ;;
        esac
        exit 0
    fi

    load_module "menu"
    main_menu
}

main "$@"

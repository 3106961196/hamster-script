#!/bin/bash

# WSL: /mnt/c copies may leave CRLF — fix /cs before sourcing anything
_hamster_fix_crlf_if_needed() {
    local root entry
    for root in "/cs" "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." 2>/dev/null && pwd)"; do
        [[ -f "$root/lib/bin_entry.sh" ]] || continue
        entry="$root/lib/bin_entry.sh"
        grep -q $'\r' "$entry" 2>/dev/null || return 0
        find "$root" -type f \( -name '*.sh' -o -path '*/bin/*' -o -name '*.conf' \) \
            -exec sed -i 's/\r$//' {} + 2>/dev/null || true
        chmod +x "$root"/bin/* 2>/dev/null || true
        if [[ -w /usr/local/bin && -f "$root/bin/cs" ]]; then
            sed 's/\r$//' "$root/bin/cs" > /usr/local/bin/cs && chmod 755 /usr/local/bin/cs
            [[ -f "$root/bin/nt" ]] && sed 's/\r$//' "$root/bin/nt" > /usr/local/bin/nt && chmod 755 /usr/local/bin/nt
        fi
        return 0
    done
}
_hamster_fix_crlf_if_needed

_entry=""
for _p in "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/bin_entry.sh" "/cs/lib/bin_entry.sh"; do
    [[ -f "$_p" ]] && { _entry="$_p"; break; }
done
[[ -z "$_entry" ]] && { echo "错误：未找到 bin_entry.sh"; exit 1; }

# shellcheck source=/dev/null
source "$_entry"
仓鼠_bin引导 "${BASH_SOURCE[0]}"
初始化核心

_显示帮助() {
    echo "用法: cs [命令]"
    echo ""
    echo "命令:"
    echo "  (无参数)    启动主菜单"
    echo "  update, r   更新脚本"
    echo "  tmux        进入 tmux 桌面"
    echo "  version     显示版本"
    echo "  help, -h    查看帮助"
}

程序入口() {
    if [[ $# -gt 0 ]]; then
        case "$1" in
            r|update)
                加载模块 "update"
                更新_执行
                ;;
            tmux)
                exec bash "$PROJECT_ROOT/config/tmux/tmux.sh" "${@:2}"
                ;;
            version)
                echo "${PROJECT_NAME} v${PROJECT_VERSION}"
                ;;
            help|-h|--help)
                _显示帮助
                ;;
            *)
                echo "未知命令: $1"
                _显示帮助
                exit 1
                ;;
        esac
        exit 0
    fi

    加载模块 "menu"
    主菜单
}

程序入口 "$@"

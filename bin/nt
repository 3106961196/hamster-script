#!/bin/bash

_hamster_fix_crlf_if_needed() {
    local root entry
    for root in "/cs" "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." 2>/dev/null && pwd)"; do
        [[ -f "$root/lib/bin_entry.sh" ]] || continue
        entry="$root/lib/bin_entry.sh"
        grep -q $'\r' "$entry" 2>/dev/null || return 0
        find "$root" -type f \( -name '*.sh' -o -path '*/bin/*' -o -name '*.conf' \) \
            -exec sed -i 's/\r$//' {} + 2>/dev/null || true
        chmod +x "$root"/bin/* 2>/dev/null || true
        if [[ -w /usr/local/bin && -f "$root/bin/nt" ]]; then
            sed 's/\r$//' "$root/bin/nt" > /usr/local/bin/nt && chmod 755 /usr/local/bin/nt
            [[ -f "$root/bin/cs" ]] && sed 's/\r$//' "$root/bin/cs" > /usr/local/bin/cs && chmod 755 /usr/local/bin/cs
        fi
        return 0
    done
}
_hamster_fix_crlf_if_needed

_entry=""
for _p in "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/bin_entry.sh" "/cs/lib/bin_entry.sh"; do
    [[ -f "$_p" ]] && { _entry="$_p"; break; }
done
[[ -z "$_entry" ]] && { echo "错误：未找到 bin_entry.sh"; exit 1; }

# shellcheck source=/dev/null
source "$_entry"
仓鼠_bin引导 "${BASH_SOURCE[0]}"
工具引导
工具_加载 "$PROJECT_ROOT/tools/napcat/install.sh"
NapCat_加载配置
NapCat_确保依赖 || exit 1

if [[ -n "${1:-}" ]]; then
    NapCat_添加或更新QQ "$1" "${2:-${NAPCAT_DEFAULT_PORT:-2537}}"
    NapCat_启动QQ "$1"
fi

exec bash "$PROJECT_ROOT/tools/napcat/manage.sh"
